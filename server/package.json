{
    "name": "cake-constructor-server",
    "version": "1.0.0",
    "description": "Бэкенд для конструктора тортов",
    "scripts": {
        "dev": "nodemon --exec \"ts-node --project tsconfig.json\" index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "npx prisma migrate dev",
        "db:seed": "npx prisma db seed",
        "db:studio": "npx prisma studio"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.19.0",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.0.0",
        "nodemon": "^3.1.0",
        "prisma": "^6.19.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.0"
    }
}
