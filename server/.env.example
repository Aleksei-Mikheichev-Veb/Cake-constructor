# ============================================================
# .env — Переменные окружения
# ============================================================
# Этот файл НЕ коммитится в git (он в .gitignore).
# Скопируй .env.example в .env и заполни значения.
# ============================================================

# Строка подключения к PostgreSQL
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ
DATABASE_URL="postgresql://postgres:password@localhost:5432/cake_constructor"

# Секрет для JWT-токенов (замени на случайную строку!)
# Можно сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-key-change-me"

# Порт сервера
PORT=4000

# URL фронтенда (для CORS)
FRONTEND_URL="http://localhost:3000"

# Тип хранилища файлов: "local" или "s3"
STORAGE_TYPE="local"

# Настройки S3 (заполнять, только если STORAGE_TYPE=s3)
# S3_REGION="ru-central1"
# S3_ENDPOINT="https://storage.yandexcloud.net"
# S3_BUCKET="cake-images"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_CDN_URL="https://cake-images.storage.yandexcloud.net"
