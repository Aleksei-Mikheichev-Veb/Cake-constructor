# ============================================================
# server/.env.example
# Скопируй в .env и заполни своими значениями.
# На Render эти же переменные добавляются в Environment.
# ============================================================

NODE_ENV=development
PORT=4000

# ─── База (Supabase) ────────────────────────────────────────
# DATABASE_URL — pooled connection (порт 6543, pgBouncer),
# используется Prisma Client в runtime
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL — direct connection (порт 5432), используется
# только миграциями. Prisma сам подставит при migrate deploy.
DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── JWT (админка) ──────────────────────────────────────────
JWT_SECRET="замени-на-длинную-случайную-строку-минимум-32-символа"

# ─── Cloudinary ─────────────────────────────────────────────
# Бесплатный аккаунт: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── CORS (фронтенд-домены в prod) ──────────────────────────
# В dev не обязательны, localhost:3000 и :3001 разрешены по умолчанию.
CLIENT_URL="https://your-client.vercel.app"
ADMIN_URL="https://your-admin.vercel.app"

# ─── ВКонтакте ──────────────────────────────────────────────
VK_COMMUNITY_TOKEN=""
VK_CONFECTIONER_ID=""
VK_CONFECTIONER_PROFILE_ID=""

# ─── Telegram ───────────────────────────────────────────────
TG_BOT_TOKEN=""
TG_CONFECTIONER_CHAT_ID=""
